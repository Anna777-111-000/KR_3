<Window x:Class="K3.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ИгроМир - Система управления партнерами" 
        Height="650" Width="1200"
        Loaded="Window_Loaded">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок с логотипом -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
            <Image Source="/Images/ico.jpg" Height="60" Margin="0,0,15,0" 
                   Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality"/>
            <TextBlock Text="Продукция компании ИгроМир" 
                       FontSize="24" FontWeight="Bold" 
                       FontFamily="Segoe UI" 
                       VerticalAlignment="Center"
                       Foreground="Black"/>
        </StackPanel>

        <!-- Шапка таблицы -->
        <Grid Grid.Row="1" Margin="0,0,0,5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="120"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Товар" 
                       FontWeight="Bold" FontSize="14" FontFamily="Segoe UI"
                       Foreground="Black"/>
            <TextBlock Grid.Column="2" Text="Скидка" 
                       FontWeight="Bold" FontSize="14" FontFamily="Segoe UI"
                       HorizontalAlignment="Right"
                       Foreground="Black"/>
        </Grid>

        <!-- Черная линия-разделитель -->
        <Separator Grid.Row="2" Background="Black" Height="2" Margin="0,0,0,15"/>

        <!-- Список карточек продукции -->
        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="productsControl">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="#156082"
            BorderThickness="1"
            Margin="0,0,0,15"
            CornerRadius="4"
            MouseLeftButtonDown="Card_Click"
            Cursor="Hand">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0" 
                    Background="#156082"
                    CornerRadius="4,4,0,0"
                    Padding="15,10">
                                    <TextBlock Text="{Binding Name}" 
                           FontSize="18" 
                           FontWeight="Bold" 
                           Foreground="White"
                           FontFamily="Segoe UI"/>
                                </Border>

                                <Border Grid.Row="1" Background="#FFFFFF" Padding="15,12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="120"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock FontSize="14" FontFamily="Segoe UI" Margin="0,0,0,8" Foreground="Black">
                            <Run Text="• " FontWeight="Bold"/>
                            <Run Text="Тип товара: " FontWeight="Bold"/>
                            <Run Text="{Binding ProductType}"/>
                                            </TextBlock>
                                            <TextBlock FontSize="14" FontFamily="Segoe UI" Margin="0,0,0,8" Foreground="Black">
                            <Run Text="• " FontWeight="Bold"/>
                            <Run Text="Цена без скидки: " FontWeight="Bold"/>
                            <Run Text="{Binding Price, StringFormat={}{0:F2} ₽}"/>
                                            </TextBlock>
                                            <TextBlock FontSize="14" FontFamily="Segoe UI" Foreground="Black">
                            <Run Text="• " FontWeight="Bold"/>
                            <Run Text="Цена со скидкой: " FontWeight="Bold"/>
                            <Run Text="{Binding PriceWithDiscount, StringFormat={}{0:F2} ₽}"/>
                                            </TextBlock>
                                        </StackPanel>

                                        <TextBlock Grid.Column="1" 
                               VerticalAlignment="Center"
                               HorizontalAlignment="Right"
                               FontSize="32" 
                               FontWeight="Bold"
                               Foreground="Black"
                               FontFamily="Segoe UI">
                        <Run Text="{Binding DiscountPercent}"/>
                        <Run Text="%" FontSize="20"/>
                                        </TextBlock>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Кнопки -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" 
                    HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="Добавить" Width="120" Click="AddButton_Click"/>
            <Button Content="Изменить" Width="120" Margin="10,0,0,0" Click="EditButton_Click"/>
        </StackPanel>
    </Grid>
</Window>