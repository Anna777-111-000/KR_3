<Window x:Class="K3.ProductEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Добавление продукции" 
        Height="500" Width="500"
        WindowStartupLocation="CenterOwner">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock x:Name="txtTitle" Grid.Row="0"
                       Text="Добавление продукции" 
                       FontSize="22" FontWeight="Bold" 
                       Margin="0,0,0,20"/>

            <StackPanel Grid.Row="1">
                <TextBlock Text="Наименование:" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBox x:Name="txtName" Padding="5" Margin="0,0,0,15"/>

                <TextBlock Text="Тип продукции:" FontWeight="Bold" Margin="0,0,0,5"/>
                <ComboBox x:Name="cmbType" Padding="5" Margin="0,0,0,15">
                    <ComboBoxItem Content="карточная"/>
                    <ComboBoxItem Content="семейная"/>
                    <ComboBoxItem Content="стратегическая"/>
                    <ComboBoxItem Content="детективная"/>
                    <ComboBoxItem Content="кооперативная"/>
                </ComboBox>

                <TextBlock Text="Цена (₽):" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBox x:Name="txtPrice" Padding="5" Margin="0,0,0,15"/>

                <TextBlock Text="Количество (шт.):" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBox x:Name="txtCount" Padding="5" Margin="0,0,0,15"/>
            </StackPanel>

            <StackPanel Grid.Row="2" Orientation="Horizontal" 
                        HorizontalAlignment="Right" Margin="0,15,0,0">
                <Button Content="Назад" Width="100" Margin="0,0,10,0" Click="BtnBack_Click"/>
                <Button Content="Сохранить" Width="120" Click="BtnSave_Click"/>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Window>